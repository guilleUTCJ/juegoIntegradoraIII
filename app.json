{
  "expo": {
    "name": "gameIntegradora",
    "slug": "gameIntegradora",
    "version": "1.0.0",
    "orientation": "landscape",
    "icon": "./app/assets/images/icon.jpg",
    "scheme": "gameintegradora",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./app/assets/images/icon.jpg",
        "backgroundImage": "./app/assets/images/icon.jpg",
        "monochromeImage": "./app/assets/images/icon.jpg",
        "softwareKeyboardLayoutMode": "pan",
        "screenOrientation": "landscape"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single",
      "favicon": "./app/assets/images/icon.jpg"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./app/assets/images/icon.jpg",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-audio",
      "expo-secure-store"
    ]
  }
}
